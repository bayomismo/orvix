{
  "$schema": "https://orvix.com/schemas/tokens.v1.json",
  "version": "1.0.0",
  "color": {
    "brand": {
      "primary":   { "light": "#0A0A0F", "dark": "#FAFAFA" },
      "accent":    { "light": "#5046E5", "dark": "#5046E5" },
      "accent_soft": { "light": "#EEF0FE", "dark": "#1E1A4A" },
      "ai":        { "light": "#8B5CF6", "dark": "#8B85F0" },
      "ai_soft":   { "light": "#F3EEFE", "dark": "#22153E" }
    },
    "neutral": {
      "0":   { "light": "#FFFFFF", "dark": "#08080B" },
      "50":  { "light": "#FAFAFB", "dark": "#0E0E12" },
      "100": { "light": "#F4F4F6", "dark": "#14141A" },
      "150": { "light": "#EDEDEF", "dark": "#1A1A21" },
      "200": { "light": "#E5E5E8", "dark": "#22222A" },
      "300": { "light": "#D1D1D6", "dark": "#2D2D38" },
      "400": { "light": "#A1A1AA", "dark": "#54545F" },
      "500": { "light": "#71717A", "dark": "#75757F" },
      "600": { "light": "#52525B", "dark": "#96969F" },
      "700": { "light": "#3F3F46", "dark": "#B4B4BD" },
      "800": { "light": "#27272A", "dark": "#D6D6DE" },
      "900": { "light": "#18181B", "dark": "#EDEDEF" },
      "950": { "light": "#0A0A0F", "dark": "#FAFAFA" }
    },
    "surface": {
      "canvas":    { "light": "#FAFAFB", "dark": "#08080B" },
      "raised":    { "light": "#FFFFFF", "dark": "#0E0E12" },
      "elevated":  { "light": "#FFFFFF", "dark": "#14141A" },
      "overlay":   { "light": "rgba(15,15,20,0.40)", "dark": "rgba(0,0,0,0.65)" },
      "divider":   { "light": "#EDEDEF", "dark": "#22222A" },
      "divider_strong": { "light": "#E0E0E4", "dark": "#2D2D38" },
      "inset":     { "light": "#F4F4F6", "dark": "#0A0A0F" },
      "glass":     { "light": "rgba(255,255,255,0.75)", "dark": "rgba(20,20,26,0.55)" }
    },
    "text": {
      "primary":   { "light": "#0A0A0F", "dark": "#FAFAFA" },
      "secondary": { "light": "#52525B", "dark": "#A1A1AA" },
      "muted":     { "light": "#A1A1AA", "dark": "#71717A" },
      "subtle":    { "light": "#D1D1D6", "dark": "#3F3F46" },
      "on_accent": { "light": "#FFFFFF", "dark": "#FFFFFF" },
      "link":      { "light": "#5046E5", "dark": "#8B85F0" },
      "inverse":   { "light": "#FFFFFF", "dark": "#08080B" }
    },
    "status": {
      "success":       { "light": "#059669", "dark": "#34D399" },
      "success_soft":  { "light": "#ECFDF5", "dark": "#0A2E20" },
      "warning":       { "light": "#D97706", "dark": "#FBBF24" },
      "warning_soft":  { "light": "#FEF3C7", "dark": "#3A2807" },
      "danger":        { "light": "#DC2626", "dark": "#F87171" },
      "danger_soft":   { "light": "#FEE2E2", "dark": "#3A1818" },
      "info":          { "light": "#2563EB", "dark": "#60A5FA" },
      "info_soft":     { "light": "#DBEAFE", "dark": "#0F2237" },
      "neutral":       { "light": "#52525B", "dark": "#A1A1AA" },
      "neutral_soft":  { "light": "#F4F4F6", "dark": "#1A1A21" }
    },
    "highlight": {
      "1":   { "light": "rgba(80,70,229,0.06)",  "dark": "rgba(80,70,229,0.10)" },
      "2":   { "light": "rgba(80,70,229,0.10)",  "dark": "rgba(80,70,229,0.16)" },
      "3":   { "light": "rgba(80,70,229,0.16)",  "dark": "rgba(80,70,229,0.22)" },
      "ai_1":   { "light": "rgba(139,92,246,0.06)",  "dark": "rgba(139,133,240,0.10)" },
      "ai_2":   { "light": "rgba(139,92,246,0.10)",  "dark": "rgba(139,133,240,0.18)" },
      "ai_3":   { "light": "rgba(139,92,246,0.16)",  "dark": "rgba(139,133,240,0.28)" }
    }
  },
  "font": {
    "display": {
      "family": "Geist",
      "fallback": "Inter Variable, ui-sans-serif, system-ui, sans-serif"
    },
    "body": {
      "family": "Geist",
      "fallback": "Inter Variable, ui-sans-serif, system-ui, sans-serif"
    },
    "mono": {
      "family": "Geist Mono",
      "fallback": "JetBrains Mono Variable, ui-monospace, SFMono-Regular, monospace"
    }
  },
  "type": {
    "display-2xl": { "size": "4.5rem",  "lineHeight": "1.05", "weight": "600", "letterSpacing": "-0.04em" },
    "display-xl":  { "size": "3.5rem",  "lineHeight": "1.08", "weight": "600", "letterSpacing": "-0.04em" },
    "display-lg":  { "size": "2.75rem", "lineHeight": "1.1",  "weight": "600", "letterSpacing": "-0.03em" },
    "display-md":  { "size": "2rem",    "lineHeight": "1.15", "weight": "600", "letterSpacing": "-0.02em" },
    "display-sm":  { "size": "1.5rem",  "lineHeight": "1.2",  "weight": "600", "letterSpacing": "-0.02em" },
    "text-lg":     { "size": "1rem",     "lineHeight": "1.5",  "weight": "500", "letterSpacing": "-0.01em" },
    "text-md":     { "size": "0.875rem", "lineHeight": "1.55", "weight": "400", "letterSpacing": "-0.005em" },
    "text-sm":     { "size": "0.8125rem","lineHeight": "1.5",  "weight": "400" },
    "text-xs":     { "size": "0.75rem",  "lineHeight": "1.5",  "weight": "500" },
    "text-2xs":    { "size": "0.625rem", "lineHeight": "1.4",  "weight": "600", "letterSpacing": "0.04em" },
    "data-lg":     { "size": "1.125rem", "lineHeight": "1.33","weight": "500", "family": "mono" },
    "data-md":     { "size": "0.875rem", "lineHeight": "1.43","weight": "500", "family": "mono" },
    "data-sm":     { "size": "0.75rem",  "lineHeight": "1.33","weight": "500", "family": "mono" }
  },
  "radius": {
    "none": "0",
    "xs":   "2px",
    "sm":   "4px",
    "md":   "6px",
    "lg":   "10px",
    "xl":   "16px",
    "full": "9999px"
  },
  "elevation": {
    "0":   "none",
    "1":   "0 1px 2px rgba(15,15,20,0.04), 0 0 0 1px rgba(15,15,20,0.05)",
    "2":   "0 2px 4px rgba(15,15,20,0.05), 0 4px 16px rgba(15,15,20,0.06), 0 0 0 1px rgba(15,15,20,0.05)",
    "3":   "0 4px 8px rgba(15,15,20,0.06), 0 12px 32px rgba(15,15,20,0.10), 0 0 0 1px rgba(15,15,20,0.05)",
    "4":   "0 8px 16px rgba(15,15,20,0.08), 0 24px 56px rgba(15,15,20,0.16), 0 0 0 1px rgba(15,15,20,0.06)",
    "focus": "0 0 0 2px var(--surface-canvas), 0 0 0 4px var(--brand-accent)",
    "glow_accent": "0 0 24px 0 rgba(80, 70, 229, 0.35)",
    "glow_ai": "0 0 24px 0 rgba(139, 133, 240, 0.40)"
  },
  "motion": {
    "instant":   { "duration": "80ms",  "easing": "linear" },
    "fast":      { "duration": "160ms", "easing": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "default":   { "duration": "240ms", "easing": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "slow":      { "duration": "400ms", "easing": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "ease_out_quint":    "cubic-bezier(0.16, 1, 0.3, 1)",
    "ease_in_out_quart": "cubic-bezier(0.76, 0, 0.24, 1)",
    "ease_out_back":     "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "ease_in_cubic":     "cubic-bezier(0.32, 0, 0.67, 0)",
    "ease_linear":       "linear"
  },
  "z": {
    "dropdown": 10,
    "sticky":   20,
    "overlay":  30,
    "modal":    40,
    "toast":    50,
    "palette":  60,
    "pulse":    70
  },
  "grid": {
    "app": { "maxWidth": "1280px", "gutter": "24px", "columnCount": 12 },
    "density": {
      "comfortable": { "rowHeight": "48px" },
      "dense":       { "rowHeight": "32px" }
    }
  },
  "pulse": {
    "thickness": "1px",
    "glowBlur":  "8px",
    "glowOpacity": 0.30,
    "active": {
      "color": "var(--brand-accent)",
      "glow":  "0 0 8px 0 rgba(80, 70, 229, 0.30)"
    },
    "ai": {
      "color": "var(--brand-ai)",
      "glow":  "0 0 8px 0 rgba(139, 133, 240, 0.30)"
    },
    "warning": {
      "color": "var(--status-warning)",
      "glow":  "0 0 8px 0 rgba(251, 191, 36, 0.30)"
    },
    "error": {
      "color": "var(--status-danger)",
      "glow":  "0 0 8px 0 rgba(248, 113, 113, 0.30)"
    }
  },
  "agentRules": {
    "aiColorReservedFor": "AI involvement only",
    "colorMustBePairedWith": "text or icon",
    "noColorOnlySignal": true,
    "noRawHexInFeatureCode": true,
    "useOnlyTokensViaCssVars": true
  }
}
