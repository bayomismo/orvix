{
  "name": "@orvix/utils",
  "version": "0.0.1",
  "private": true,
  "description": "Truly shared utilities: errors, result, formatters, cost primitives.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./result": "./src/result.ts",
    "./errors": "./src/errors.ts",
    "./format": "./src/format.ts",
    "./cost": "./src/cost.ts"
  },
  "scripts": {
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx --config ../../.eslintrc.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc"
  },
  "dependencies": {
    "@orvix/schemas": "workspace:*",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@orvix/config": "workspace:*",
    "vitest": "^2.1.6"
  }
}
