{
  "name": "@orvix/db",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma client + withWorkspace extension + SQL migrations + RLS policies.",
  "type": "module",
  "main": "./src/client.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./client/raw": "./src/client-raw.ts",
    "./schema": "./src/schema.prisma",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx --config ../../.eslintrc.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo \"@orvix/db build via Prisma generate\" && prisma generate --schema=src/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=src/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=src/schema.prisma",
    "db:generate": "prisma generate --schema=src/schema.prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "next-auth": "5.0.0-beta.31",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@orvix/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.16.0",
    "vitest": "^2.1.6"
  }
}
