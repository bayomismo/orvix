{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@orvix/ai-runtime": [
        "../../packages/ai-runtime/src/index.ts"
      ],
      "@orvix/config/tokens/tokens.css": [
        "../../packages/config/tokens/tokens.css"
      ],
      "@orvix/db": [
        "../../packages/db/src/index.ts"
      ],
      "@orvix/schemas": [
        "../../packages/schemas/src/index.ts"
      ],
      "@orvix/types": [
        "../../packages/types/src/index.ts"
      ],
      "@orvix/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@orvix/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@orvix/utils": [
        "../../packages/utils/src/index.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/ai-runtime/src/**/*.ts",
    "../../packages/db/src/**/*.ts",
    "../../packages/schemas/src/**/*.ts",
    "../../packages/types/src/**/*.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx",
    "../../packages/utils/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/node_modules",
    "**/dist",
    "**/generated"
  ]
}
