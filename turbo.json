{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "apps/web/.next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "NEON_DATABASE_URL",
        "ORVIX_DB_BACKEND",
        "NODE_ENV",
        "AUTH_SECRET",
        "EMAIL_SERVER",
        "EMAIL_FROM",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "MICROSOFT_ISSUER",
        "ORVIX_S3_BUCKET",
        "ORVIX_S3_ENDPOINT",
        "ORVIX_S3_REGION",
        "ORVIX_S3_ACCESS_KEY_ID",
        "ORVIX_S3_SECRET_ACCESS_KEY",
        "ORVIX_S3_FORCE_PATH_STYLE",
        "ORVIX_STORAGE_ROOT",
        "ORVIX_AI_DEFAULT_PROVIDER",
        "ORVIX_OPENAI_API_KEY",
        "ORVIX_ANTHROPIC_API_KEY",
        "ORVIX_GEMINI_API_KEY",
        "ORVIX_OPENROUTER_API_KEY",
        "ORVIX_OLLAMA_BASE_URL",
        "ORVIX_AI_URL",
        "ORVIX_ALLOW_DEV_BOOTSTRAP",
        "VERCEL",
        "VERCEL_ENV",
        "VERCEL_URL",
        "NEXT_PUBLIC_VERCEL_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": [
        "DATABASE_URL",
        "NEON_DATABASE_URL",
        "ORVIX_DB_BACKEND"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": ["**/.env.*"]
}
